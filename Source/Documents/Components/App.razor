@inject ITenantProvider Tenant
@*
    Root document. Tenant settings drive <title>, theme variables and favicon — solo
    mode falls back to Setting<T> defaults, no special handling required.

    `<Routes @rendermode="InteractiveServer" />` makes EVERY routed page interactive.
    A more realistic app would set the render mode per page (SSR by default + opt-in
    interactivity) but for a demo "just works everywhere" beats nuance.
*@
<!DOCTYPE html>
<html lang="@Tenant.Settings.Site.Language">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <base href="/" />
    @* Scoped CSS bundle (`{AssemblyName}.styles.css`) is only emitted when the host
       project or one of its referenced RCLs ships a *.razor.css file. Documents has
       none, so referencing "Documents.styles.css" here would 404 → MIME error
       ("Refused to apply style ... text/html is not a supported stylesheet MIME type").
       Add the link back the moment a *.razor.css is introduced. *@
    <link rel="stylesheet" href="site.css" />
    <link rel="icon" type="image/png" href="@(Tenant.Settings.Site.FaviconUrl ?? "favicon.png")" />
    <title>@Tenant.Settings.Site.Title</title>
    <meta name="description" content="@Tenant.Settings.Site.MetaDescription" />
    <HeadOutlet />
    @{
        var theme = Tenant.Settings.Theme;
    }
    <style>
        :root {
            --primary:   @theme.PrimaryColor;
            --secondary: @theme.SecondaryColor;
            --accent:    @theme.AccentColor;
            --neutral:   @theme.NeutralColor;
            --surface:   @theme.SurfaceColor;
            --content:   @theme.ContentColor;
        }
    </style>
</head>
<body>
    @* Persistence bridges. Each of these is an invisible component that grabs
       request-scoped state (Identity / Workspace / Catalog / Culture) during the
       SSR prerender pass via `PersistentComponentState.PersistAsJson`, and restores
       it into the circuit's scoped repository on the interactive pass. Without
       them every Blazor circuit starts with an empty IAuthenticatedRepository
       (the request scope that ran the auth middleware is long gone) and the user
       appears anonymous despite a valid Session cookie. *@
    <Routes @rendermode="InteractiveServer" />
    <script src="_framework/blazor.web.js"></script>
</body>
</html>
