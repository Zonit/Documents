@rendermode InteractiveServer
@inherits PageBase

<PageTitle>@T("AuthorizeView")</PageTitle>

<MudText Typo="Typo.h3" GutterBottom="true">&lt;AuthorizeView&gt;</MudText>

<MudText Class="mb-4">
    @T("Standard Blazor authorization component. The Roles attribute does role checks; Policy resolves through IAuthorizationPolicyProvider — Zonit's PermissionPolicyProvider synthesises a policy on the fly when the name parses as a Permission token (no AddPolicy(...) needed).")
</MudText>

<MudCard Outlined="true" Class="mb-4">
    <MudCardContent>
        <MudText Typo="Typo.h5" GutterBottom="true">@T("By role")</MudText>
        <AuthorizeView Roles="admin">
            <Authorized><MudChip T="string" Color="global::MudBlazor.Color.Success" Icon="@Icons.Material.Filled.Check">@T("Visible to administrators")</MudChip></Authorized>
            <NotAuthorized><MudChip T="string" Color="global::MudBlazor.Color.Default">@T("Hidden from non-admins")</MudChip></NotAuthorized>
        </AuthorizeView>
        <pre class="mud-elevation-1 pa-3 mt-3" style="background:var(--mud-palette-background-grey);border-radius:4px;">&lt;AuthorizeView Roles="admin"&gt;...&lt;/AuthorizeView&gt;</pre>
    </MudCardContent>
</MudCard>

<MudCard Outlined="true" Class="mb-4">
    <MudCardContent>
        <MudText Typo="Typo.h5" GutterBottom="true">@T("By concrete permission")</MudText>
        <AuthorizeView Policy="users.read">
            <Authorized><MudChip T="string" Color="global::MudBlazor.Color.Success" Icon="@Icons.Material.Filled.Check">@T("You hold users.read")</MudChip></Authorized>
            <NotAuthorized><MudChip T="string" Color="global::MudBlazor.Color.Default">@T("No users.read permission")</MudChip></NotAuthorized>
        </AuthorizeView>
        <pre class="mud-elevation-1 pa-3 mt-3" style="background:var(--mud-palette-background-grey);border-radius:4px;">&lt;AuthorizeView Policy="users.read"&gt;...&lt;/AuthorizeView&gt;</pre>
    </MudCardContent>
</MudCard>

<MudCard Outlined="true" Class="mb-4">
    <MudCardContent>
        <MudText Typo="Typo.h5" GutterBottom="true">@T("By wildcard permission")</MudText>
        <MudText Class="mb-3">
            @T("The admin user holds '*' which implies everything. The standard user holds only users.read — they are denied below.")
        </MudText>
        <AuthorizeView Policy="settings.write">
            <Authorized><MudChip T="string" Color="global::MudBlazor.Color.Success" Icon="@Icons.Material.Filled.Check">@T("You hold settings.write (or a wildcard)")</MudChip></Authorized>
            <NotAuthorized><MudChip T="string" Color="global::MudBlazor.Color.Default">@T("No settings.write")</MudChip></NotAuthorized>
        </AuthorizeView>
        <pre class="mud-elevation-1 pa-3 mt-3" style="background:var(--mud-palette-background-grey);border-radius:4px;">&lt;AuthorizeView Policy="settings.write"&gt;...&lt;/AuthorizeView&gt;</pre>
    </MudCardContent>
</MudCard>

<MudCard Outlined="true">
    <MudCardContent>
        <MudText Typo="Typo.h5" GutterBottom="true">@T("Authorization context")</MudText>
        <MudText Class="mb-3">@T("You can inspect the current principal directly:")</MudText>
        <AuthorizeView>
            <Authorized Context="auth">
                <pre class="mud-elevation-1 pa-3" style="background:var(--mud-palette-background-grey);border-radius:4px;">@($@"auth.User.Identity?.Name        -> {auth.User.Identity?.Name}
auth.User.IsInRole(""user"")      -> {auth.User.IsInRole("user")}
Claims:
{string.Join("\n", auth.User.Claims.Select(c => $"  {c.Type} = {c.Value}"))}")</pre>
            </Authorized>
            <NotAuthorized>
                <MudAlert Severity="Severity.Info" Variant="Variant.Outlined">@T("Anonymous.")</MudAlert>
            </NotAuthorized>
        </AuthorizeView>
    </MudCardContent>
</MudCard>
