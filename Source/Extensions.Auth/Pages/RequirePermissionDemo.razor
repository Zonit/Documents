@rendermode InteractiveServer
@inherits PageBase

<PageTitle>@T("[RequirePermission] page")</PageTitle>

<MudText Typo="Typo.h3" GutterBottom="true">@T("[RequirePermission] page")</MudText>

<MudText Class="mb-4">
    @T("The whole page is gated by [RequirePermission(\"users.read\")] — the attribute is its own IAuthorizationRequirementData so no AddPolicy(...) is needed. Anonymous visitors land here only because <AuthorizeRouteView> shows our custom 403 panel; logged-in users without users.read see the same.")
</MudText>

<MudAlert Severity="Severity.Success" Variant="Variant.Outlined" Class="mb-4">
    <strong>@T("You are authorized.")</strong> @T("Holders of users.read reach this content.")
</MudAlert>

<MudCard Outlined="true" Class="mb-4">
    <MudCardContent>
        <MudText Typo="Typo.h5" GutterBottom="true">@T("Equivalent declarations")</MudText>
        <pre class="mud-elevation-1 pa-3" style="background:var(--mud-palette-background-grey);border-radius:4px;">@(@"// Razor / Blazor pages
@attribute [RequirePermission(""users.read"")]

// Components / classes
[RequirePermission(""users.read"")]
public partial class UsersPage : PageBase { }

// Minimal API
app.MapGet(""/api/users"", () => ...)
   .RequireAuthorization(new RequirePermissionAttribute(""users.read""));

// Controllers
[RequirePermission(""users.write"")]
public IActionResult Update(...) => ...;")</pre>
    </MudCardContent>
</MudCard>

<MudCard Outlined="true">
    <MudCardContent>
        <MudText Typo="Typo.h5" GutterBottom="true">@T("Wildcard requirement")</MudText>
        <MudText Class="mb-3">
            @T("Try clicking the link to a fictional admin page that requires settings.write. The standard user account is denied by both the route view and the RequirePermissionAttribute handler — admin gets in.")
        </MudText>
        <MudButton Variant="Variant.Filled" Color="global::MudBlazor.Color.Primary"
                   Href="@AdminOnly.Route" StartIcon="@Icons.Material.Filled.AdminPanelSettings">
            @T("Admin-only page")
        </MudButton>
    </MudCardContent>
</MudCard>
