@rendermode InteractiveServer
@inherits PageEditBase<Extensions.Components.Models.TaskViewModel>
@using Extensions.Components.Models

<PageTitle>@T("[AutoSave] per-field saving")</PageTitle>

<MudText Typo="Typo.h3" GutterBottom="true">@T("[AutoSave] per-field saving")</MudText>

<MudText Class="mb-4">
    @T("Properties decorated with [AutoSave] (optionally [AutoSave(DelayMs=…)]) trigger AutoSaveAsync(fieldName, oldValue, newValue, ct) after a debounce interval. The override below pushes a toast — a real app would PATCH the field to its backend.")
</MudText>

<MudCard Outlined="true" Class="mb-4">
    <MudCardContent>
        <EditForm EditContext="@EditContext" OnValidSubmit="HandleValidSubmit" FormName="autosave">
            <DataAnnotationsValidator />

            @* Default InputText / InputTextArea notify EditContext on `onchange` (blur),
               so the AutoSave debounce only starts after the user leaves the field. For a
               true "save while typing" experience the inputs must notify on EVERY keystroke.
               We bypass InputBase here and wire `oninput` -> Model + NotifyFieldChanged. *@
            <MudStack Spacing="3">
                <MudTextField T="string" Value="@Model.Title"
                              ValueChanged="@(v => OnFieldInput(nameof(Model.Title), v))"
                              Immediate="true" Variant="Variant.Outlined"
                              Label="@T("Title")" HelperText="@T("(no auto-save)")" />

                <MudTextField T="string" Value="@Model.Notes"
                              ValueChanged="@(v => OnFieldInput(nameof(Model.Notes), v))"
                              Immediate="true" Variant="Variant.Outlined"
                              Lines="3" Label="@T("Notes")" HelperText="[AutoSave(1500ms)]" />

                <MudTextField T="string" Value="@Model.Priority.ToString()"
                              ValueChanged="@(v => OnPriorityInput(v))"
                              Immediate="true" Variant="Variant.Outlined"
                              Label="@T("Priority")" HelperText="[AutoSave]" />

                <MudButton ButtonType="ButtonType.Submit" Variant="Variant.Filled"
                           Color="global::MudBlazor.Color.Primary" StartIcon="@Icons.Material.Filled.Send">
                    @T("Submit anyway")
                </MudButton>
            </MudStack>
        </EditForm>
    </MudCardContent>
</MudCard>

<MudCard Outlined="true">
    <MudCardContent>
        <MudText Typo="Typo.h5" GutterBottom="true">@T("Auto-save log")</MudText>
        @if (_log.Count == 0)
        {
            <MudText Typo="Typo.body2" Color="global::MudBlazor.Color.Secondary">
                @T("Edit \"Notes\" or \"Priority\" and pause typing — entries appear here.")
            </MudText>
        }
        else
        {
            <MudList T="string" Dense="true">
                @foreach (var entry in _log)
                {
                    <MudListItem T="string" Icon="@Icons.Material.Filled.Save">
                        <code>@entry</code>
                    </MudListItem>
                }
            </MudList>
        }
    </MudCardContent>
</MudCard>
