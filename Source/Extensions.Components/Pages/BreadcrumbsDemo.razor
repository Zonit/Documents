@rendermode InteractiveServer
@inherits PageBase

<PageTitle>@T("Breadcrumbs")</PageTitle>

<MudText Typo="Typo.h3" GutterBottom="true">@T("Breadcrumbs")</MudText>

<MudText Class="mb-4">
    @T("PageBase exposes BreadcrumbsProvider; the recommended pattern is to override ShowBreadcrumbs and Breadcrumbs on the page — they are pushed automatically on init.")
</MudText>

<MudCard Outlined="true" Class="mb-4">
    <MudCardContent>
        <MudText Typo="Typo.h5" GutterBottom="true">@T("This page's breadcrumbs")</MudText>
        @if (BreadcrumbsProvider.Get() is { Count: > 0 } crumbs)
        {
            <MudBreadcrumbs Items="@crumbs.Select(b => new BreadcrumbItem(b.Text.Value, b.Href.HasValue ? b.Href.Value : null, b.Disabled)).ToList()" />
        }
        else
        {
            <MudText Typo="Typo.body2" Color="global::MudBlazor.Color.Secondary">@T("(none)")</MudText>
        }
    </MudCardContent>
</MudCard>

<MudCard Outlined="true">
    <MudCardContent>
        <MudText Typo="Typo.h5" GutterBottom="true">@T("Recipe")</MudText>
        <pre class="mud-elevation-1 pa-3" style="background:var(--mud-palette-background-grey);border-radius:4px;">@(@"@inherits PageBase

protected override bool? ShowBreadcrumbs => true;

protected override List<BreadcrumbsModel> Breadcrumbs =>
[
    new() { Text = ""Home"",       Href = ""/"" },
    new() { Text = ""Components"", Href = ""/components"" },
    new() { Text = ""Breadcrumbs""                       },   // current page — no Href
];")</pre>
    </MudCardContent>
</MudCard>
