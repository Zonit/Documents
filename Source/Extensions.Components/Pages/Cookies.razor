@rendermode InteractiveServer
@inherits PageBase

<PageTitle>@T("Cookies")</PageTitle>

<MudText Typo="Typo.h3" GutterBottom="true">@T("Cookies")</MudText>

<MudText Class="mb-4">
    @T("ICookieProvider wraps two completely different worlds: HttpOnly cookies issued server-side by middleware (e.g. the auth Session cookie), and JS-visible cookies set from the interactive circuit via document.cookie. Reads pass through a per-circuit snapshot — call RefreshAsync() once on first interactive render to populate it (HTTP-request scope ≠ circuit scope in Blazor Server, so the server-side seed never reaches the circuit on its own).")
</MudText>

<MudCard Outlined="true" Class="mb-4">
    <MudCardContent>
        <MudText Typo="Typo.h5" GutterBottom="true">@T("Read & write")</MudText>
        <MudTextField @bind-Value="_value" Immediate="true" Variant="Variant.Outlined"
                      Label="@T("Demo cookie value")" Class="mb-3" />
        <MudStack Row="true" Spacing="2">
            <MudButton Variant="Variant.Filled" Color="global::MudBlazor.Color.Primary"
                       StartIcon="@Icons.Material.Filled.Save" OnClick="Save">@T("Save (1 day)")</MudButton>
            <MudButton Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.Download" OnClick="Load">@T("Load")</MudButton>
            <MudButton Variant="Variant.Outlined" Color="global::MudBlazor.Color.Error"
                       StartIcon="@Icons.Material.Filled.Delete" OnClick="Delete">@T("Delete")</MudButton>
        </MudStack>
        @if (_loaded is not null)
        {
            <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Class="mt-3">
                @TM("Last Get(): <strong>{0}</strong>", _loaded)
            </MudAlert>
        }
    </MudCardContent>
</MudCard>

<MudCard Outlined="true">
    <MudCardContent>
        <MudText Typo="Typo.h5" GutterBottom="true">@T("Cookies visible to JavaScript")</MudText>
        <MudText Typo="Typo.body2" Color="global::MudBlazor.Color.Secondary" Class="mb-3">
            @T("Hydrated by Cookie.RefreshAsync() on first interactive render. HttpOnly cookies (the auth session cookie among them) are not listed here — browsers hide them from document.cookie on purpose. That is a feature, not a bug: HttpOnly is exactly how the session cookie defends itself against XSS.")
        </MudText>

        @if (Cookie.GetCookies() is { Count: > 0 } cookies)
        {
            <MudSimpleTable Dense="true" Hover="true" Bordered="true">
                <thead><tr><th>@T("Name")</th><th>@T("Value")</th></tr></thead>
                <tbody>
                    @foreach (var c in cookies)
                    {
                        <tr><td><code>@c.Name</code></td><td><code>@c.Value</code></td></tr>
                    }
                </tbody>
            </MudSimpleTable>
        }
        else
        {
            <MudAlert Severity="Severity.Info" Variant="Variant.Outlined">
                @T("(none visible to JS — log in first or click Save above to seed one).")
            </MudAlert>
        }

        <MudButton Variant="Variant.Outlined" Class="mt-3"
                   StartIcon="@Icons.Material.Filled.Refresh" OnClick="Refresh">
            @T("Refresh from browser")
        </MudButton>
    </MudCardContent>
</MudCard>
