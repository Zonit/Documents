@inherits PageBase

<div style="padding: 40px; max-width: 720px; margin: 0 auto; font-family: ui-sans-serif, system-ui, sans-serif;">
    <h1>[NoLayout]</h1>
    <p>
        @T("Zero chrome — no MainLayout, no DemoBoxLayout, no wrapping <LayoutView>. The HTML you see above (right after the <body> tag) is whatever this page emits directly.")
    </p>
    <p>
        @T("Use cases: embeddable widgets, OAuth popups, framed third-party content, diagnostic pages, error pages that must work even when the main layout's injected services crash.")
    </p>
    <p>
        @T("Authorization still applies: [Authorize] / [RequirePermission] on this class would be honoured by ZonitRouteView's wrapped AuthorizeRouteView.")
    </p>
    <p>
        <a href="@Layouts.Route">← @T("Back to layout demo")</a>
    </p>
</div>
