@inherits PageBase

<h1>[LayoutKey("Demo.Box")] — @T("static")</h1>

<p>
    @T("This page is rendered inside DemoBoxLayout purely because of the [LayoutKey(\"Demo.Box\")] attribute on the class. There is no @layout directive in this file and the page's compiled type carries no compile-time reference to DemoBoxLayout — the resolver looked the key up in ILayoutRegistry at render time.")
</p>

<p>
    @T("Note that none of the usual chrome (top nav, side menu, footer) is present — that's because the layout-by-key resolution wins over the Site default MainLayout.")
</p>

<p>
    <a href="@Layouts.Route">← @T("Back")</a>
</p>
