@rendermode InteractiveServer
@inherits PageEditBase<Extensions.Components.Models.TaskViewModel>
@using Extensions.Components.Models

<PageTitle>PageEditBase&lt;T&gt;</PageTitle>

<MudText Typo="Typo.h3" GutterBottom="true">PageEditBase&lt;T&gt;</MudText>

<MudText Class="mb-4">
    @T("Form base class with: EditContext + DataAnnotations validation, HasChanges tracking, automatic string trim & whitespace normalisation on submit, duplicate-submit guard, translated validation messages, and [AutoSave] per-field auto-save (see next page).")
</MudText>

<MudCard Outlined="true" Class="mb-4">
    <MudCardContent>
        <EditForm EditContext="@EditContext" OnValidSubmit="HandleValidSubmit" OnInvalidSubmit="HandleInvalidSubmit" FormName="task-edit">
            <DataAnnotationsValidator />

            <MudStack Spacing="3">
                <div>
                    <InputText @bind-Value="Model.Title" class="mud-input-slot mud-input-root mud-input-root-outlined" placeholder="@T("Title")" />
                    <ValidationMessage For="@(() => Model.Title)" />
                </div>

                <div>
                    <InputTextArea @bind-Value="Model.Notes" rows="3" class="mud-input-slot mud-input-root mud-input-root-outlined" placeholder="@T("Notes")" />
                    <ValidationMessage For="@(() => Model.Notes)" />
                </div>

                <div>
                    <InputNumber @bind-Value="Model.Priority" class="mud-input-slot mud-input-root mud-input-root-outlined" placeholder="@T("Priority (1–5)")" />
                    <ValidationMessage For="@(() => Model.Priority)" />
                </div>

                <div>
                    <InputDate @bind-Value="Model.DueDate" class="mud-input-slot mud-input-root mud-input-root-outlined" />
                </div>

                <MudCheckBox @bind-Value="Model.Completed" Label="@T("Completed")" />

                <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
                    <MudButton ButtonType="ButtonType.Submit"
                               Variant="Variant.Filled"
                               Color="global::MudBlazor.Color.Primary"
                               Disabled="@(!HasChanges || Processing)"
                               StartIcon="@Icons.Material.Filled.Save">
                        @(Processing ? T("Saving…") : T("Save"))
                    </MudButton>
                    <MudButton Variant="Variant.Outlined" Disabled="@(!HasChanges || Processing)" OnClick="Reset">
                        @T("Reset")
                    </MudButton>
                    <MudText Typo="Typo.caption" Color="global::MudBlazor.Color.Secondary">
                        HasChanges: @HasChanges · IsValid: @IsValid
                    </MudText>
                </MudStack>
            </MudStack>
        </EditForm>
    </MudCardContent>
</MudCard>

<MudCard Outlined="true">
    <MudCardContent>
        <MudText Typo="Typo.h5" GutterBottom="true">@T("What happens on submit")</MudText>
        <MudList T="string" Dense="true">
            <MudListItem T="string" Icon="@Icons.Material.Filled.LooksOne">DataAnnotations.Validator.TryValidateObject @T("runs (translated messages).")</MudListItem>
            <MudListItem T="string" Icon="@Icons.Material.Filled.LooksTwo">@T("If AutoTrimStrings / AutoNormalizeWhitespace are on (defaults: true), CleanModelData() runs before SubmitAsync.")</MudListItem>
            <MudListItem T="string" Icon="@Icons.Material.Filled.Looks3">SubmitAsync(CancellationToken) @T("is invoked — your save call goes here.")</MudListItem>
            <MudListItem T="string" Icon="@Icons.Material.Filled.Looks4">Toast.AddSuccess(...) @T("+ HasChanges reset to false.")</MudListItem>
        </MudList>
    </MudCardContent>
</MudCard>
