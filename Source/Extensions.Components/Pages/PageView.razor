@rendermode InteractiveServer
@inherits PageViewBase<Extensions.Components.Models.TaskViewModel>
@using Extensions.Components.Models

<PageTitle>PageViewBase&lt;T&gt;</PageTitle>

<MudText Typo="Typo.h3" GutterBottom="true">PageViewBase&lt;T&gt;</MudText>

<MudText Class="mb-4">
    @T("PageViewBase<T> is a thin wrapper for read-only pages. It owns the Model, supplies a LoadAsync hook, exposes IsLoading, and (by default) persists the model into PersistentComponentState so the transition SSR → InteractiveServer happens without a second load.")
</MudText>

@if (IsLoading || Model is null)
{
    <MudProgressCircular Color="global::MudBlazor.Color.Primary" Indeterminate="true" />
    <MudText Class="ml-3 d-inline">@T("Loading…")</MudText>
}
else
{
    <MudCard Outlined="true" Class="mb-4">
        <MudCardContent>
            <MudText Typo="Typo.h5" GutterBottom="true">@Model.Title</MudText>
            <MudSimpleTable Dense="true" Bordered="true">
                <tbody>
                    <tr><td><strong>@T("Priority")</strong></td><td>@Model.Priority</td></tr>
                    <tr><td><strong>@T("Due")</strong></td><td>@Model.DueDate</td></tr>
                    <tr><td><strong>@T("Completed")</strong></td><td>@Model.Completed</td></tr>
                </tbody>
            </MudSimpleTable>
            <MudText Class="mt-3">@Model.Notes</MudText>
        </MudCardContent>
        <MudCardActions>
            <MudButton Variant="Variant.Filled" Color="global::MudBlazor.Color.Primary"
                       StartIcon="@Icons.Material.Filled.Refresh" OnClick="Reload">
                @T("Reload")
            </MudButton>
        </MudCardActions>
    </MudCard>
}

<MudCard Outlined="true">
    <MudCardContent>
        <MudText Typo="Typo.h5" GutterBottom="true">@T("How it works")</MudText>
        <pre class="mud-elevation-1 pa-3" style="background:var(--mud-palette-background-grey);border-radius:4px;">@(@"@inherits PageViewBase<TaskViewModel>

protected override async Task<TaskViewModel?> LoadAsync(CancellationToken ct)
{
    // your data layer call
    return await _store.GetCurrentTaskAsync(ct);
}")</pre>
    </MudCardContent>
</MudCard>
