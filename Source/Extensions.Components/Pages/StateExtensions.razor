@rendermode InteractiveServer
@inherits PageBase

@*
    Auth / Culture / Workspace / Catalog are already exposed by ExtensionsBase as
    `Authenticated` / `Culture` / `Workspace` / `Catalog` protected properties — no
    @inject needed (and re-injecting them would shadow the base hooks that subscribe
    to OnChange for auto re-render).
*@

<PageTitle>@T("State extensions — prerender ↔ interactive bridge")</PageTitle>

<MudText Typo="Typo.h3" GutterBottom="true">@T("State extensions — prerender ↔ interactive bridge")</MudText>

<MudText Class="mb-2">
    @T("Blazor renders interactive pages twice — once on the server (SSR / prerender) and again after the circuit is established. Identity, organisation, project and culture are all request-scoped on the server but vanish when the circuit reconnects. The four Zonit*Extension components persist that state through PersistentComponentState so the second render sees exactly what the first one saw — no flicker, no extra round-trip, no JSInterop dance.")
</MudText>

<MudText Typo="Typo.body2" Color="global::MudBlazor.Color.Secondary" Class="mb-4">
    @T("UseWebsite<App>() already injects these into App.razor; the page below just reads the providers they hydrate, so reloading shows the same values immediately on both render passes.")
</MudText>

<MudCard Outlined="true" Class="mb-4">
    <MudCardContent>
        <MudText Typo="Typo.h5" GutterBottom="true">ZonitIdentityExtension → IAuthenticatedProvider</MudText>
        @if (!Authenticated.Current.HasValue)
        {
            <MudAlert Severity="Severity.Info" Variant="Variant.Outlined">
                @TM("Anonymous — log in via {0}.", "<a href=\"login\">/login</a>")
            </MudAlert>
        }
        else
        {
            <pre class="mud-elevation-1 pa-3" style="background:var(--mud-palette-background-grey);border-radius:4px;">@($@"Authenticated.Current.Id    -> {Authenticated.Current.Id}
Authenticated.Current.Name  -> {Authenticated.Current.Name.Value}
Authenticated.Current.Roles -> {string.Join(", ", Authenticated.Current.Roles.Select(r => r.Value))}")</pre>
        }
    </MudCardContent>
</MudCard>

<MudCard Outlined="true" Class="mb-4">
    <MudCardContent>
        <MudText Typo="Typo.h5" GutterBottom="true">ZonitCulturesExtension → ICultureProvider</MudText>
        <pre class="mud-elevation-1 pa-3" style="background:var(--mud-palette-background-grey);border-radius:4px;">@($@"Culture.Current.Value         -> {Culture.Current.Value}
Culture.Current.NativeName    -> {Culture.Current.NativeName}")</pre>
        <MudText Typo="Typo.caption" Color="global::MudBlazor.Color.Secondary" Class="mt-2 d-block">
            @T("Switch the culture in the top-bar — both the prerender and the interactive circuit will land on the value you picked, persisted via this extension.")
        </MudText>
    </MudCardContent>
</MudCard>

<MudCard Outlined="true" Class="mb-4">
    <MudCardContent>
        <MudText Typo="Typo.h5" GutterBottom="true">ZonitOrganizationsExtension → IWorkspaceProvider</MudText>
        @if (!Workspace.Organization.HasValue)
        {
            <MudAlert Severity="Severity.Info" Variant="Variant.Outlined">
                @TM("No active organisation. Pick one at {0}.", "<a href=\"/docs/organizations\">/docs/organizations</a>")
            </MudAlert>
        }
        else
        {
            <pre class="mud-elevation-1 pa-3" style="background:var(--mud-palette-background-grey);border-radius:4px;">@($@"Workspace.Organization.Id    -> {Workspace.Organization.Id}
Workspace.Organization.Name  -> {Workspace.Organization.Name.Value}")</pre>
        }
    </MudCardContent>
</MudCard>

<MudCard Outlined="true" Class="mb-4">
    <MudCardContent>
        <MudText Typo="Typo.h5" GutterBottom="true">ZonitProjectsExtension → ICatalogProvider</MudText>
        @if (!Catalog.Project.HasValue)
        {
            <MudAlert Severity="Severity.Info" Variant="Variant.Outlined">
                @TM("No active project. Pick one at {0}.", "<a href=\"/docs/projects\">/docs/projects</a>")
            </MudAlert>
        }
        else
        {
            <pre class="mud-elevation-1 pa-3" style="background:var(--mud-palette-background-grey);border-radius:4px;">@($@"Catalog.Project.Id    -> {Catalog.Project.Id}
Catalog.Project.Name  -> {Catalog.Project.Name.Value}
Catalog.Visible.Length-> {Catalog.Visible.Length}")</pre>
        }
    </MudCardContent>
</MudCard>

<MudCard Outlined="true">
    <MudCardContent>
        <MudText Typo="Typo.h5" GutterBottom="true">@T("How they wire up")</MudText>
        <MudText>
            @T("These four components are mounted by UseWebsite<App>() via the source-generated HeadOutlet-style insertion. You only see them in DOM as <persistent-component-state> entries in the prerender markup — no visible UI. The pattern works for any request-scoped state: write your own Zonit*Extension against PersistentComponentState.PersistAsJson(JsonTypeInfo, …) and you stay AOT-safe (see OrganizationsStateJsonContext.cs for the recipe).")
        </MudText>
    </MudCardContent>
</MudCard>
