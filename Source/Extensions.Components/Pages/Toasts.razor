@rendermode InteractiveServer
@inherits PageBase

<PageTitle>@T("Toasts")</PageTitle>

<MudText Typo="Typo.h3" GutterBottom="true">@T("Toasts")</MudText>

<MudText Class="mb-4">
    @T("IToastProvider queues lightweight notifications keyed by ToastType. The provider is layout-agnostic — the rendering UI lives in your layout / MudBlazor area. Here we just push toasts and let the host display them (open the dev console to see them in action even without a renderer).")
</MudText>

<MudCard Outlined="true" Class="mb-4">
    <MudCardContent>
        <MudText Typo="Typo.h5" GutterBottom="true">@T("Try the API")</MudText>
        <MudStack Row="true" Spacing="2" Wrap="Wrap.Wrap">
            <MudButton Variant="Variant.Filled" Color="global::MudBlazor.Color.Success" StartIcon="@Icons.Material.Filled.CheckCircle"
                       OnClick='() => Toast.AddSuccess("Saved!")'>@T("Success")</MudButton>
            <MudButton Variant="Variant.Filled" Color="global::MudBlazor.Color.Info" StartIcon="@Icons.Material.Filled.Info"
                       OnClick='() => Toast.AddInfo("FYI")'>@T("Info")</MudButton>
            <MudButton Variant="Variant.Filled" Color="global::MudBlazor.Color.Warning" StartIcon="@Icons.Material.Filled.Warning"
                       OnClick='() => Toast.AddWarning("Heads up")'>@T("Warning")</MudButton>
            <MudButton Variant="Variant.Filled" Color="global::MudBlazor.Color.Error" StartIcon="@Icons.Material.Filled.Error"
                       OnClick='() => Toast.AddError("Boom")'>@T("Error")</MudButton>
            <MudButton Variant="Variant.Outlined" Color="global::MudBlazor.Color.Default"
                       OnClick='() => Toast.AddNormal("Plain message")'>@T("Normal")</MudButton>
        </MudStack>
    </MudCardContent>
</MudCard>

<MudCard Outlined="true" Class="mb-4">
    <MudCardContent>
        <MudText Typo="Typo.h5" GutterBottom="true">@T("With format args")</MudText>
        <pre class="mud-elevation-1 pa-3 mb-3" style="background:var(--mud-palette-background-grey);border-radius:4px;">Toast.AddSuccess("Created {0} (#{1})", "Order", 42);</pre>
        <MudButton Variant="Variant.Filled" Color="global::MudBlazor.Color.Primary" StartIcon="@Icons.Material.Filled.Send"
                   OnClick='() => Toast.AddSuccess("Created {0} (#{1})", "Order", 42)'>@T("Push")</MudButton>
    </MudCardContent>
</MudCard>

<MudCard Outlined="true">
    <MudCardContent>
        <MudText Typo="Typo.h5" GutterBottom="true">@T("Where to render them")</MudText>
        <MudText>
            @T("The MudBlazor area (Zonit.Extensions.Website.MudBlazor) renders toasts through MudBlazor's snackbar. Custom layouts can subscribe to IToastProvider's underlying queue and render manually.")
        </MudText>
    </MudCardContent>
</MudCard>
