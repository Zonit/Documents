@rendermode InteractiveServer
@inherits PageEditBase<Extensions.MudBlazor.Models.FormModel>
@using Extensions.MudBlazor.Models
@using MudBlazor

@*
    MudBlazor providers/assets are global on the /docs (dashboard) mount, so they are
    NOT re-declared here. The home page on the public root mount keeps its own scoped
    providers — see Documents.Website/Pages/Home.razor.
*@

<PageTitle>@T("MudBlazor + Zonit value objects")</PageTitle>

<MudText Typo="global::MudBlazor.Typo.h3" GutterBottom="true">@T("MudBlazor + Zonit value objects")</MudText>

<MudText Class="mb-4">
    @TM("{0} and {1} wrap {2} with a Value-Object-aware converter. {3} is inferred from {4} — the consumer never spells it out. Construction errors thrown by the VO (e.g. {5}) are caught and rendered as MudBlazor validation messages; the offending text is preserved so the user can fix it in place.",
        "<code>ZonitTextField&lt;T&gt;</code>",
        "<code>ZonitTextArea&lt;T&gt;</code>",
        "<code>MudTextField</code>",
        "<code>T</code>",
        "<code>@bind-Value</code>",
        "<code>Url(\"nope\")</code>")
</MudText>

<MudAlert Severity="global::MudBlazor.Severity.Info" Variant="global::MudBlazor.Variant.Outlined" Class="mb-4">
    @TM("This page derives from {0} — the framework supplies {1}, {2}, {3} tracking, duplicate-submit guard, and string trim/whitespace normalisation on submit. The page only overrides {4} (initial seed) and {5} (the save call).",
        "<strong>PageEditBase&lt;FormModel&gt;</strong>",
        "<code>Model</code>",
        "<code>EditContext</code>",
        "<code>HasChanges</code>",
        "<code>LoadAsync</code>",
        "<code>SubmitAsync</code>")
</MudAlert>

<MudPaper Class="pa-6 mb-6" Elevation="2">
    <EditForm EditContext="@EditContext" OnValidSubmit="HandleValidSubmit" FormName="mud-vo-form">
        <DataAnnotationsValidator />

        <ZonitTextField @bind-Value="Model.Title"       Label="@T("Title")"       Counter="0" />
        <ZonitTextField @bind-Value="Model.Slug"        Label="@T("URL slug")"    HelperText="@T("Lower-case, hyphens, ASCII.")" />
        <ZonitTextField @bind-Value="Model.HomeUrl"     Label="@T("Homepage")"    OpenNewTab />
        <ZonitTextArea  @bind-Value="Model.Description" Label="@T("Description")" Counter="0" Lines="3" />

        @* MudBlazor enums are qualified with global::MudBlazor. because @using Zonit.Extensions
           (inherited from _Imports.razor) brings in a Color VO that would otherwise shadow
           MudBlazor.Color. The Zonit VO wins on simple-name lookup so we anchor MudBlazor. *@
        <MudStack Row="true" Spacing="2" AlignItems="global::MudBlazor.AlignItems.Center" Class="mt-4">
            <MudButton ButtonType="global::MudBlazor.ButtonType.Submit"
                       Variant="global::MudBlazor.Variant.Filled"
                       Color="global::MudBlazor.Color.Primary"
                       StartIcon="@(global::MudBlazor.Icons.Material.Filled.Save)"
                       Disabled="@(!HasChanges || Processing)">
                @(Processing ? T("Saving…") : T("Save"))
            </MudButton>
            <MudText Typo="global::MudBlazor.Typo.caption" Color="global::MudBlazor.Color.Secondary">
                HasChanges: @HasChanges · IsValid: @IsValid
            </MudText>
        </MudStack>
    </EditForm>
</MudPaper>

<MudPaper Class="pa-6" Elevation="1">
    <MudText Typo="global::MudBlazor.Typo.h6" GutterBottom="true">@T("Current snapshot")</MudText>
    <pre class="mud-elevation-1 pa-3" style="background:var(--mud-palette-background-grey);border-radius:4px;">@($@"Title       -> ""{Model.Title.Value}"" (length {Model.Title.Length} / {Title.MaxLength})
Slug        -> ""{Model.Slug.Value}""
HomeUrl     -> ""{Model.HomeUrl.Value}"" (abs: {Model.HomeUrl.IsAbsolute})
Description -> ""{Model.Description.Value}"" (length {Model.Description.Length} / {Description.MaxLength})")</pre>
</MudPaper>
