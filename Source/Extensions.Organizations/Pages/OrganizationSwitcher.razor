@rendermode InteractiveServer
@inherits PageBase

<PageTitle>@T("Organization switcher")</PageTitle>

<MudText Typo="Typo.h3" GutterBottom="true">@T("Organization switcher")</MudText>

<MudText Class="mb-4">
    @T("IWorkspaceManager mutates the per-scope state (Initialize / SwitchOrganizationAsync) and fires OnChange. Page subscribes via PageBase so the switch is reflected without a manual refresh.")
</MudText>

@if (Manager.Organizations is { Count: > 0 } orgs)
{
    <MudCard Outlined="true" Class="mb-4">
        <MudCardContent>
            <MudText Typo="Typo.h5" GutterBottom="true">@T("Pick one")</MudText>
            <MudList T="Guid" Dense="true">
                @foreach (var org in orgs)
                {
                    var isCurrent = org.Id == Workspace.Organization.Id;
                    <MudListItem T="Guid" Disabled="@isCurrent" OnClick="@(() => SwitchTo(org.Id))">
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                            <MudIcon Icon="@(isCurrent ? Icons.Material.Filled.CheckCircle : Icons.Material.Outlined.Business)"
                                     Color="@(isCurrent ? global::MudBlazor.Color.Success : global::MudBlazor.Color.Default)" />
                            <div>
                                <MudText Typo="Typo.body1"><strong>@org.Name</strong></MudText>
                                <MudText Typo="Typo.caption" Color="global::MudBlazor.Color.Secondary">@org.City, @org.Country</MudText>
                            </div>
                        </MudStack>
                    </MudListItem>
                }
            </MudList>
        </MudCardContent>
    </MudCard>
}
else
{
    <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Class="mb-4">
        @T("Log in to see your organizations.")
    </MudAlert>
}

<MudCard Outlined="true">
    <MudCardContent>
        <MudText Typo="Typo.h5" GutterBottom="true">@T("Switching projects")</MudText>
        <MudText>
            @TM("Switching organizations resets the project scope. See {0}.", "<a href=\"/docs/projects/switcher\">/docs/projects/switcher</a>")
        </MudText>
    </MudCardContent>
</MudCard>
