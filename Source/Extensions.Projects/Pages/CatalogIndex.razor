@rendermode InteractiveServer
@inherits PageBase

<PageTitle>@T("Catalog")</PageTitle>

<MudText Typo="Typo.h3" GutterBottom="true">@T("Catalog")</MudText>

<MudText Class="mb-4">
    @T("ICatalogProvider exposes the current project as a Project value object. Hydrated by ProjectMiddleware from IProjectSource; scoped to the active organization, so an org switch invalidates the project automatically.")
</MudText>

@if (!Catalog.Project.HasValue)
{
    <MudAlert Severity="Severity.Info" Variant="Variant.Outlined">@T("No project selected.")</MudAlert>
}
else
{
    <MudCard Outlined="true">
        <MudCardContent>
            <MudText Typo="Typo.h5" GutterBottom="true">@T("Current")</MudText>
            <MudSimpleTable Dense="true" Bordered="true">
                <tbody>
                    <tr><td><strong>Id</strong></td><td><code>@Catalog.Project.Id</code></td></tr>
                    <tr><td><strong>@T("Name")</strong></td><td>@Catalog.Project.Name.Value</td></tr>
                    <tr><td><strong>@T("Slug")</strong></td><td>@Catalog.Project.Slug.Value</td></tr>
                </tbody>
            </MudSimpleTable>
        </MudCardContent>
    </MudCard>
}
