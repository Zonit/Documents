@rendermode InteractiveServer
@inherits PageBase

<PageTitle>@T("Project switcher")</PageTitle>

<MudText Typo="Typo.h3" GutterBottom="true">@T("Project switcher")</MudText>

@if (Manager.Projects is { Count: > 0 } projects)
{
    <MudCard Outlined="true">
        <MudCardContent>
            <MudText Typo="Typo.h5" GutterBottom="true">@T("Pick one")</MudText>
            <MudList T="Guid" Dense="true">
                @foreach (var p in projects)
                {
                    var isCurrent = p.Id == Catalog.Project.Id;
                    <MudListItem T="Guid" Disabled="@isCurrent" OnClick="@(() => SwitchTo(p.Id))">
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                            <MudIcon Icon="@(isCurrent ? Icons.Material.Filled.CheckCircle : Icons.Material.Outlined.Inventory2)"
                                     Color="@(isCurrent ? global::MudBlazor.Color.Success : global::MudBlazor.Color.Default)" />
                            <MudText>@p.Name</MudText>
                        </MudStack>
                    </MudListItem>
                }
            </MudList>
        </MudCardContent>
    </MudCard>
}
else
{
    <MudAlert Severity="Severity.Info" Variant="Variant.Outlined">@T("No projects under the current organization.")</MudAlert>
}
