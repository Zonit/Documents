@rendermode InteractiveServer
@inherits PageBase

<PageTitle>@T("Solo vs multi-site")</PageTitle>

<MudText Typo="Typo.h3" GutterBottom="true">@T("Solo vs multi-site")</MudText>

<MudText Class="mb-3">
    @T("TenantMiddleware auto-detects single-site hosts. There are two cases that end up in the same place:")
</MudText>

<MudList T="string" Dense="true" Class="mb-4">
    <MudListItem T="string" Icon="@Icons.Material.Filled.LooksOne">@T("The host did NOT register an ITenantSource at all.")</MudListItem>
    <MudListItem T="string" Icon="@Icons.Material.Filled.LooksTwo">@T("The registered manager returned null for the current host name.")</MudListItem>
</MudList>

<MudText Class="mb-4">
    @T("Either way, the middleware seeds ITenantRepository with Tenant.Solo — a sentinel with Id == Guid.Empty and Domain == \"*\". The result: ITenantProvider.Current is never null, settings always surface either persisted overrides or the compile-time defaults, and pages don't need null-checks.")
</MudText>

<MudCard Outlined="true" Class="mb-4">
    <MudCardContent>
        <MudText Typo="Typo.h5" GutterBottom="true">@T("Right now")</MudText>
        <MudSimpleTable Dense="true" Bordered="true">
            <tbody>
                <tr><td><strong>Id</strong></td><td><code>@Tenant.Current?.Id</code></td></tr>
                <tr><td><strong>@T("Domain")</strong></td><td>@Tenant.Current?.Domain</td></tr>
                <tr><td><strong>IsSolo</strong></td><td>@Tenant.Current?.IsSolo</td></tr>
                <tr><td><strong>@T("Vars")</strong></td><td>@(Tenant.Current?.Variables.Count ?? 0)</td></tr>
            </tbody>
        </MudSimpleTable>
    </MudCardContent>
</MudCard>

<MudCard Outlined="true">
    <MudCardContent>
        <MudText Typo="Typo.h5" GutterBottom="true">@T("How to flip the demo")</MudText>
        <pre class="mud-elevation-1 pa-3" style="background:var(--mud-palette-background-grey);border-radius:4px;">@(@"// Program.cs
// Comment this out to force solo-mode globally:
// builder.Services.AddScoped<ITenantSource, InMemoryTenantManager>();")</pre>
    </MudCardContent>
</MudCard>
