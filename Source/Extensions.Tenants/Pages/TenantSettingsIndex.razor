@rendermode InteractiveServer
@inherits PageBase

<PageTitle>@T("Tenant settings")</PageTitle>

<MudText Typo="Typo.h3" GutterBottom="true">@T("Tenant settings")</MudText>

<MudText Class="mb-2">
    @T("ITenantProvider surfaces hydrated Setting<T> instances. The auto-generated TenantSettings partial class adds one strongly-typed property per Setting<T>, visible at compile time.")
</MudText>

<MudText Typo="Typo.body2" Color="global::MudBlazor.Color.Secondary" Class="mb-4">
    @T("The localhost tenant overrides site and theme; any other host falls back to defaults via Tenant.Solo.")
</MudText>

<MudCard Outlined="true" Class="mb-4">
    <MudCardContent>
        <MudText Typo="Typo.h5" GutterBottom="true">@T("Site")</MudText>
        <MudSimpleTable Dense="true" Bordered="true">
            <tbody>
                <tr><td><strong>@T("Title")</strong></td><td>@Tenant.Settings.Site.Title</td></tr>
                <tr><td><strong>@T("Meta description")</strong></td><td>@Tenant.Settings.Site.MetaDescription</td></tr>
                <tr><td><strong>@T("Default language")</strong></td><td>@Tenant.Settings.Site.Language</td></tr>
                <tr><td><strong>@T("Logo")</strong></td><td>@(Tenant.Settings.Site.LogoUrl ?? T("(default)"))</td></tr>
                <tr><td><strong>@T("Favicon")</strong></td><td>@(Tenant.Settings.Site.FaviconUrl ?? T("(default)"))</td></tr>
            </tbody>
        </MudSimpleTable>
    </MudCardContent>
</MudCard>

<MudCard Outlined="true" Class="mb-4">
    <MudCardContent>
        <MudText Typo="Typo.h5" GutterBottom="true">@T("Theme")</MudText>
        <MudStack Row="true" Wrap="Wrap.Wrap" Spacing="2">
            <MudPaper Class="px-4 py-2" Style="@($"background:{Tenant.Settings.Theme.PrimaryColor};color:white;")">primary</MudPaper>
            <MudPaper Class="px-4 py-2" Style="@($"background:{Tenant.Settings.Theme.SecondaryColor};color:white;")">secondary</MudPaper>
            <MudPaper Class="px-4 py-2" Style="@($"background:{Tenant.Settings.Theme.AccentColor};color:white;")">accent</MudPaper>
            <MudPaper Class="px-4 py-2" Style="@($"background:{Tenant.Settings.Theme.NeutralColor};color:{Tenant.Settings.Theme.ContentColor};")">neutral</MudPaper>
            <MudPaper Class="px-4 py-2" Style="@($"background:{Tenant.Settings.Theme.SurfaceColor};color:{Tenant.Settings.Theme.ContentColor};")">surface</MudPaper>
        </MudStack>
    </MudCardContent>
</MudCard>

<MudCard Outlined="true" Class="mb-4">
    <MudCardContent>
        <MudText Typo="Typo.h5" GutterBottom="true">@T("Maintenance")</MudText>
        <MudText>@TM("Active: <strong>{0}</strong>", Tenant.Settings.Maintenance.IsActive)</MudText>
        <MudText>@T("Message: {0}", Tenant.Settings.Maintenance.MaintenanceMessage ?? T("(none)"))</MudText>
    </MudCardContent>
</MudCard>

<MudCard Outlined="true">
    <MudCardContent>
        <MudText Typo="Typo.h5" GutterBottom="true">@T("Social media")</MudText>
        <MudList T="string" Dense="true">
            <MudListItem T="string" Icon="@Icons.Custom.Brands.Facebook">Facebook: @(Tenant.Settings.SocialMedia.Facebook ?? "—")</MudListItem>
            <MudListItem T="string" Icon="@Icons.Custom.Brands.Twitter">X: @(Tenant.Settings.SocialMedia.X ?? "—")</MudListItem>
            <MudListItem T="string" Icon="@Icons.Custom.Brands.Instagram">Instagram: @(Tenant.Settings.SocialMedia.Instagram ?? "—")</MudListItem>
            <MudListItem T="string" Icon="@Icons.Custom.Brands.LinkedIn">LinkedIn: @(Tenant.Settings.SocialMedia.LinkedIn ?? "—")</MudListItem>
            <MudListItem T="string" Icon="@Icons.Custom.Brands.YouTube">YouTube: @(Tenant.Settings.SocialMedia.YouTube ?? "—")</MudListItem>
        </MudList>
    </MudCardContent>
</MudCard>
