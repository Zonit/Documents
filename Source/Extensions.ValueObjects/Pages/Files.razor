@rendermode InteractiveServer
@inherits PageBase
@using Microsoft.AspNetCore.Components.Forms
@using MudBlazor
@using ZColor = Zonit.Extensions.Color

<PageTitle>@T("File-shaped value objects")</PageTitle>

<MudText Typo="Typo.h3" GutterBottom="true">@T("File-shaped value objects")</MudText>

<MudText Class="mb-4">
    @T("Asset is the headline file VO: pick a file, get an immutable snapshot that already knows its bytes, MIME type (validated against magic bytes — not just the extension), SHA-256, signature, and pretty-printed size. FileSize and Color are tiny helpers reused all over the codebase.")
</MudText>

<MudCard Outlined="true" Class="mb-4">
    <MudCardContent>
        <MudText Typo="Typo.h5" GutterBottom="true">Asset — @T("drop a file")</MudText>

        <MudFileUpload T="IBrowserFile" OnFilesChanged="@(async e => await OnFile(e))">
            <ActivatorContent>
                <MudButton Variant="Variant.Filled" Color="global::MudBlazor.Color.Primary" StartIcon="@Icons.Material.Filled.CloudUpload">
                    @T("Pick file")
                </MudButton>
            </ActivatorContent>
        </MudFileUpload>

        @if (_asset.HasValue)
        {
            <pre class="mud-elevation-1 pa-3 mt-3" style="background:var(--mud-palette-background-grey);border-radius:4px;">@($@"asset.OriginalName  -> {_asset.OriginalName.Value}
asset.UniqueName    -> {_asset.UniqueName}
asset.Extension     -> {_asset.Extension}
asset.MediaType     -> {_asset.MediaType.Value}
asset.Signature     -> {_asset.Signature}
asset.Size          -> {_asset.Size}
asset.Sha256        -> {_asset.Sha256}
asset.CreatedAt     -> {_asset.CreatedAt:O}")</pre>

            @if (_asset.MediaType.Value.StartsWith("image/"))
            {
                <MudText Typo="Typo.caption" Color="global::MudBlazor.Color.Secondary" Class="mt-2 d-block">
                    @T("Preview (rendered straight from Asset.DataUrl):")
                </MudText>
                <MudPaper Class="pa-2 mt-2 d-inline-block">
                    <img src="@_asset.DataUrl" alt="@_asset.OriginalName.Value" style="max-width:240px;display:block;" />
                </MudPaper>
            }
        }
        else if (_error is not null)
        {
            <MudAlert Severity="Severity.Error" Variant="Variant.Outlined" Class="mt-3">@_error</MudAlert>
        }
    </MudCardContent>
</MudCard>

@{ FileSize.TryParse(_sizeInput, null, out var parsed); }
<MudCard Outlined="true" Class="mb-4">
    <MudCardContent>
        <MudText Typo="Typo.h5" GutterBottom="true">FileSize — @T("pretty-print")</MudText>
        <pre class="mud-elevation-1 pa-3 mb-3" style="background:var(--mud-palette-background-grey);border-radius:4px;">@($@"FileSize.OneKilobyte         -> {FileSize.OneKilobyte}
FileSize.OneMegabyte         -> {FileSize.OneMegabyte}
FileSize.OneGigabyte         -> {FileSize.OneGigabyte}
FileSize.HundredMegabytes    -> {FileSize.HundredMegabytes}
new FileSize(15_000_000_000) -> {new FileSize(15_000_000_000)}")</pre>

        <MudText Typo="Typo.caption" Color="global::MudBlazor.Color.Secondary" Class="mt-2 d-block">
            @T("Bytes round-trip through FileSize.TryParse(\"1.5 GB\", null, out var f):")
        </MudText>
        <MudTextField @bind-Value="_sizeInput" Immediate="true" Variant="Variant.Outlined" Label="@T("Size")" Class="my-3" />
        <pre class="mud-elevation-1 pa-3" style="background:var(--mud-palette-background-grey);border-radius:4px;">@($@"FileSize.TryParse(""{_sizeInput}"") -> {(parsed.Bytes > 0 ? parsed.ToString() : "(invalid)")}")</pre>
    </MudCardContent>
</MudCard>

@{ ZColor.TryParse(_color, null, out var c); }
<MudCard Outlined="true">
    <MudCardContent>
        <MudText Typo="Typo.h5" GutterBottom="true">Color — hex, RGB, OKLCH @T("roundtrip")</MudText>
        <MudTextField @bind-Value="_color" Immediate="true" Variant="Variant.Outlined" Label="@T("Hex")" Class="mb-3" />
        <MudPaper Class="pa-3 mb-3" Style="@($"background:{c.Hex};height:48px;border-radius:4px;")"></MudPaper>
        <pre class="mud-elevation-1 pa-3" style="background:var(--mud-palette-background-grey);border-radius:4px;">@($@"Color.TryParse(""{_color}"") ->
    Hex   = {c.Hex}
    OKLCH = L={c.L:0.00} C={c.C:0.00} H={c.H:0.0}
    Alpha = {c.Alpha}")</pre>
    </MudCardContent>
</MudCard>
