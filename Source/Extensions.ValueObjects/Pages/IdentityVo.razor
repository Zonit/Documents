@rendermode InteractiveServer
@inherits PageBase
@using MudBlazor

<PageTitle>Identity / Role / Permission</PageTitle>

<MudText Typo="Typo.h3" GutterBottom="true">Identity / Role / Permission</MudText>

<MudText Class="mb-4">
    @T("The Identity VO carries Id + Name + Roles + Permissions. Roles and permissions are tiny VOs validated on construction; permissions support wildcards via Permission.Implies.")
</MudText>

<MudCard Outlined="true" Class="mb-4">
    <MudCardContent>
        <MudText Typo="Typo.h5" GutterBottom="true">@T("Construction")</MudText>
        <pre class="mud-elevation-1 pa-3" style="background:var(--mud-palette-background-grey);border-radius:4px;">@(@"// Id-only — typical for foreign-key columns
Identity id = Guid.NewGuid();          // implicit

// Full snapshot
var hydrated = new Identity(
    Guid.NewGuid(),
    ""Linus Pauling"",
    roles:       new[] { Role.Create(""admin"") },
    permissions: new[] { Permission.Create(""orders.*"") });")</pre>
    </MudCardContent>
</MudCard>

@{
    Permission.TryCreate("orders.*", out var granted);
    Permission.TryCreate("orders.read", out var requested);
    Permission.TryCreate("invoices.read", out var unrelated);
}
<MudCard Outlined="true" Class="mb-4">
    <MudCardContent>
        <MudText Typo="Typo.h5" GutterBottom="true">@T("Wildcards: Permission.Implies")</MudText>
        <MudText Class="mb-2">
            @T("Tokens are dot-separated; * matches everything below a segment. Implies(other) returns true when the holder satisfies other.")
        </MudText>
        <pre class="mud-elevation-1 pa-3" style="background:var(--mud-palette-background-grey);border-radius:4px;">@($@"granted = ""orders.*""
granted.Implies(""orders.read"")   -> {granted.Implies(requested)}
granted.Implies(""invoices.read"") -> {granted.Implies(unrelated)}")</pre>
    </MudCardContent>
</MudCard>

<MudCard Outlined="true">
    <MudCardContent>
        <MudText Typo="Typo.h5" GutterBottom="true">@T("Current identity")</MudText>
        @if (!Authenticated.Current.HasValue)
        {
            <MudAlert Severity="Severity.Info" Variant="Variant.Outlined">@T("Anonymous — log in to populate.")</MudAlert>
        }
        else
        {
            <pre class="mud-elevation-1 pa-3" style="background:var(--mud-palette-background-grey);border-radius:4px;">@($@"Authenticated.Current.Id                 -> {Authenticated.Current.Id}
Authenticated.Current.Name.Value         -> {Authenticated.Current.Name.Value}
Authenticated.Current.IsInRole(""admin"")  -> {Authenticated.Current.IsInRole(Role.TryCreate("admin", out var r) ? r : Role.Empty)}
Authenticated.Current.HasPermission(""orders.read"")
                                          -> {Authenticated.Current.HasPermission(Permission.TryCreate("orders.read", out var p) ? p : Permission.Empty)}")</pre>
        }
    </MudCardContent>
</MudCard>
