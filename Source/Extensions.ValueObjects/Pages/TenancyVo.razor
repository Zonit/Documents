@rendermode InteractiveServer
@inherits PageBase
@using MudBlazor
@using TimeZone = Zonit.Extensions.TimeZone

<PageTitle>@T("Tenancy value objects")</PageTitle>

<MudText Typo="Typo.h3" GutterBottom="true">@T("Tenancy value objects")</MudText>

<MudText Class="mb-4">
    @T("Organization and Project follow the same pattern as Identity: readonly struct with Id + lightweight snapshot, implicit Guid ↔ VO, equality by Id, hand-rolled JSON / TypeConverter.")
</MudText>

<MudCard Outlined="true" Class="mb-4">
    <MudCardContent>
        <MudText Typo="Typo.h5" GutterBottom="true">@T("Composite VO recipe")</MudText>
        <pre class="mud-elevation-1 pa-3" style="background:var(--mud-palette-background-grey);border-radius:4px;">@(@"public sealed class Order
{
    public Identity     Author       { get; init; }
    public Organization Organization { get; init; }   // FK as VO
    public Project      Project      { get; init; }
    public Money        Total        { get; init; }
}")</pre>
        <MudText Typo="Typo.caption" Color="global::MudBlazor.Color.Secondary" Class="mt-2 d-block">
            @T("EF column type: Guid (via the implicit operator). Zonit.Extensions.Databases hydrates snapshots on demand: repo.Extension(x => x.Author).GetAsync().")
        </MudText>
    </MudCardContent>
</MudCard>

<MudCard Outlined="true" Class="mb-4">
    <MudCardContent>
        <MudText Typo="Typo.h5" GutterBottom="true">@T("Current scope")</MudText>
        <MudSimpleTable Dense="true" Bordered="true">
            <tbody>
                <tr><td><strong>Organization</strong></td><td>@(Workspace.Organization.HasValue ? $"{Workspace.Organization.Name.Value} ({Workspace.Organization.Id})" : "(none)")</td></tr>
                <tr><td><strong>Project</strong></td><td>@(Catalog.Project.HasValue ? $"{Catalog.Project.Name.Value} ({Catalog.Project.Id})" : "(none)")</td></tr>
            </tbody>
        </MudSimpleTable>
    </MudCardContent>
</MudCard>

@{
    Culture pl = "pl-PL";
    TimeZone warsaw = "Europe/Warsaw";
    TimeZone fixedOffset = 2;
}
<MudCard Outlined="true">
    <MudCardContent>
        <MudText Typo="Typo.h5" GutterBottom="true">Culture / TimeZone</MudText>
        <pre class="mud-elevation-1 pa-3" style="background:var(--mud-palette-background-grey);border-radius:4px;">@($@"Culture pl       = ""pl-PL"";         -> {pl.Value}
TimeZone warsaw  = ""Europe/Warsaw"";  -> {warsaw.Value} (offset {warsaw.Offset})
TimeZone fixed+2 = 2;                -> {fixedOffset.Value} (fixed: {fixedOffset.IsFixedOffset})
warsaw.ConvertFromUtc(DateTime.UtcNow) -> {warsaw.ConvertFromUtc(DateTime.UtcNow):u}")</pre>
    </MudCardContent>
</MudCard>
