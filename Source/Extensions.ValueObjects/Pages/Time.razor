@rendermode InteractiveServer
@inherits PageBase
@using MudBlazor
@using TimeZone = Zonit.Extensions.TimeZone

<PageTitle>@T("Time-shaped value objects")</PageTitle>

<MudText Typo="Typo.h3" GutterBottom="true">@T("Time-shaped value objects")</MudText>

<MudText Class="mb-4">
    @T("Two time-domain VOs: TimeZone wraps an IANA / fixed-offset zone identifier with implicit string ↔ VO and int → VO (for fixed offsets); Schedule is a cron-flavoured rule used by background workers and \"next run\" displays.")
</MudText>

@{
    TimeZone warsaw = "Europe/Warsaw";
    TimeZone newYork = "America/New_York";
    TimeZone fixedPlusTwo = 2;
    var nowUtc = DateTime.UtcNow;
}
<MudCard Outlined="true" Class="mb-4">
    <MudCardContent>
        <MudText Typo="Typo.h5" GutterBottom="true">TimeZone</MudText>
        <pre class="mud-elevation-1 pa-3" style="background:var(--mud-palette-background-grey);border-radius:4px;">@($@"TimeZone warsaw = ""Europe/Warsaw""
    .Value                  -> {warsaw.Value}
    .Offset                 -> {warsaw.Offset}
    .IsFixedOffset          -> {warsaw.IsFixedOffset}
    .ConvertFromUtc(now)    -> {warsaw.ConvertFromUtc(nowUtc):u}

TimeZone newYork = ""America/New_York""
    .ConvertFromUtc(now)    -> {newYork.ConvertFromUtc(nowUtc):u}

TimeZone fixed+2 = 2
    .Value                  -> {fixedPlusTwo.Value}
    .IsFixedOffset          -> {fixedPlusTwo.IsFixedOffset}")</pre>
    </MudCardContent>
</MudCard>

@{
    var everyMinute = Schedule.EveryMinute();
    var nineAm = Schedule.EveryDay(atHour: 9);
    var fridayEvening = Schedule.EveryWeek(DayOfWeek.Friday, atHour: 22);
    var firstOfMonth = Schedule.EveryMonth(onDay: 1, atHour: 0);
    var monthEnd = Schedule.EveryMonth(onDay: -1, atHour: 23, atMinute: 59);
    var refTime = new DateTimeOffset(2026, 5, 15, 12, 0, 0, TimeSpan.Zero);
}
<MudCard Outlined="true" Class="mb-4">
    <MudCardContent>
        <MudText Typo="Typo.h5" GutterBottom="true">Schedule — @T("calendar mode")</MudText>
        <MudText Class="mb-2">
            @T("Each calendar field defaults to wildcard (null); set the ones you care about and leave the rest alone. The factory helpers cover the common cases without needing to remember which fields to set.")
        </MudText>
        <pre class="mud-elevation-1 pa-3" style="background:var(--mud-palette-background-grey);border-radius:4px;">@($@"// Schedule.EveryMinute()                 — every minute at :00
//   .GetNextOccurrence({refTime:u})
//   ->  {everyMinute.GetNextOccurrence(refTime)?.ToString("u") ?? "(none)"}

// Schedule.EveryDay(atHour: 9)            — daily 09:00
//   .GetNextOccurrence({refTime:u})
//   ->  {nineAm.GetNextOccurrence(refTime)?.ToString("u") ?? "(none)"}

// Schedule.EveryWeek(Friday, atHour: 22)  — Friday 22:00
//   .GetNextOccurrence({refTime:u})
//   ->  {fridayEvening.GetNextOccurrence(refTime)?.ToString("u") ?? "(none)"}

// Schedule.EveryMonth(onDay: 1)           — first of month at midnight
//   .GetNextOccurrence({refTime:u})
//   ->  {firstOfMonth.GetNextOccurrence(refTime)?.ToString("u") ?? "(none)"}

// Schedule.EveryMonth(onDay: -1, 23, 59)  — month-end at 23:59 (-1 = last day)
//   .GetNextOccurrence({refTime:u})
//   ->  {monthEnd.GetNextOccurrence(refTime)?.ToString("u") ?? "(none)"}")</pre>
    </MudCardContent>
</MudCard>

@{
    var every30s = Schedule.EverySeconds(30);
    var every5m = Schedule.EveryMinutes(5);
    var every6h = Schedule.EveryHours(6);
    var startupBoost = Schedule.Now();
}
<MudCard Outlined="true" Class="mb-4">
    <MudCardContent>
        <MudText Typo="Typo.h5" GutterBottom="true">Schedule — @T("interval mode")</MudText>
        <MudText Class="mb-2">
            @T("Set Interval for \"run every N seconds/minutes/hours\" cadences. Calendar fields are ignored when an interval is present.")
        </MudText>
        <pre class="mud-elevation-1 pa-3" style="background:var(--mud-palette-background-grey);border-radius:4px;">@($@"Schedule.EverySeconds(30).Interval -> {every30s.Interval}
Schedule.EveryMinutes(5).Interval  -> {every5m.Interval}
Schedule.EveryHours(6).Interval    -> {every6h.Interval}
Schedule.Now().IsNow               -> {startupBoost.IsNow}")</pre>
    </MudCardContent>
</MudCard>

@{
    var parts = (_time ?? string.Empty).Split(':');
    var h = int.TryParse(parts.ElementAtOrDefault(0), out var hv) ? hv : 9;
    var m = int.TryParse(parts.ElementAtOrDefault(1), out var mv) ? mv : 0;
    if (h < 0 || h > 23) h = 9;
    if (m < 0 || m > 59) m = 0;
    var custom = Schedule.EveryDay(h, m);
    var next = custom.GetNextOccurrence(DateTimeOffset.UtcNow);
}
<MudCard Outlined="true">
    <MudCardContent>
        <MudText Typo="Typo.h5" GutterBottom="true">@T("Try it — pick a time, see the next match")</MudText>
        <MudText Class="mb-2">@T("Daily schedule at the time you pick (24h, HH:mm):")</MudText>
        <MudTextField @bind-Value="_time" Immediate="true" Variant="Variant.Outlined" Label="HH:mm" Placeholder="09:00" Class="mb-3" />
        <pre class="mud-elevation-1 pa-3" style="background:var(--mud-palette-background-grey);border-radius:4px;">@($@"Schedule.EveryDay({h}, {m}).GetNextOccurrence(now)
  ->  {next?.ToString("u") ?? "(none)"}")</pre>
    </MudCardContent>
</MudCard>
